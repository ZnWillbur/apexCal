<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.apexcal.presentation.controller.WelcomeController"
            prefHeight="720.0"
            prefWidth="1100.0"
            styleClass="app-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="32.0" right="32.0" bottom="32.0" left="32.0" />
    </padding>

    <center>
        <HBox alignment="CENTER" spacing="28.0">
            <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                <Label styleClass="app-mark" text="ApexCal" />
                <Label styleClass="headline" text="面向在校大学生的轻量级日程管理" wrapText="true" />
                <Label styleClass="lead" text="已支持课表导入、周月年视图、任务增删改查、DDL 管理、系统托盘与桌面小窗，默认使用本地 SQLite 持久化。" wrapText="true" />
                <Region prefHeight="16.0" />
                <HBox spacing="14.0">
                    <Button mnemonicParsing="false" onAction="#handleStartAction" styleClass="primary-button" text="开始自律" />
                    <Button mnemonicParsing="false" onAction="#handleExitAction" styleClass="secondary-button" text="我要打游戏" />
                </HBox>
            </VBox>

            <VBox spacing="14.0" styleClass="summary-card" HBox.hgrow="NEVER">
                <Label styleClass="card-title" text="今日摘要" />
                <Label fx:id="courseSummaryLabel" styleClass="summary-line" />
                <Label fx:id="customSummaryLabel" styleClass="summary-line" />
                <Label fx:id="deadlineSummaryLabel" styleClass="summary-line" />
                <Region prefHeight="12.0" />
                <Label styleClass="hint-text" text="这里会实时显示今天的课程、自建任务和 DDL 摘要，桌面小窗与托盘入口也会同步刷新。" wrapText="true" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
